# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4

# Memory Backend Configuration
# Options: asmr, sqlite, semantic
MEMORY_BACKEND=semantic

# ASMR Integration (if using agent-memory-system)
ASMR_PATH=../agent-memory-system

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_MINUTE=100000

# Timeouts (in seconds)
TOOL_TIMEOUT=10
LLM_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
SQLITE_DB_PATH=data/conversations.db
SAMPLE_DB_PATH=data/sample.db
